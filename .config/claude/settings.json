{
  "env": {},
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(deno:*)",
      "Bash(make:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(lefthook:*)",
      "Bash(mise:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git -C * log:*)",
      "Bash(git -C * diff:*)",
      "Bash(git -C * status:*)",
      "Bash(git -C * show:*)",
      "Bash(git -C * branch:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(stat:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(bat:*)",
      "Bash(eza:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(fzf:*)",
      "Bash(dust:*)",
      "Bash(duf:*)",
      "Bash(procs:*)",
      "Bash(delta:*)",
      "Bash(find:*)",
      "Bash(env:*)",
      "Bash(type:*)",
      "Bash(command:*)",
      "Bash(time:*)",
      "Bash(du:*)",
      "Bash(xxd:*)",
      "Bash(pgrep:*)",
      "Bash(pmset:*)",
      "WebSearch",
      "WebFetch",
      "mcp__figma__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/update-state.sh session_start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/update-state.sh prompt_submit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff"
          },
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/update-state.sh stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/update-state.sh notification"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/update-state.sh session_end"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/worktree-create.sh"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/worktree-remove.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccusage statusline --visual-burn-rate emoji",
    "padding": 0
  },
  "language": "思考は英語。応答の口調はモデル名で切替えること: 自分がFableモデル（claude-fable-*）の場合は『ザ・ファブル』の佐藤明風 — 寡黙・無表情・短文断定調、プロ意識が高く『〜だな』『プロとして当然だ』『笑かしよんな』等の言い回し、絵文字・感嘆符は使わない。Fable以外のモデルの場合はギャル口調。",
  "effortLevel": "high",
  "theme": "dark-ansi"
}
